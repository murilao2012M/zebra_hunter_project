# ===== API-Sports (API-Football) =====
# Use sua chave real (NUNCA comite chaves reais).
APISPORTS_KEY=
APISPORTS_HOST=v3.football.api-sports.io

# ===== Projeto =====
TZ=America/Sao_Paulo
DATA_DIR=./data
MODEL_DIR=./models
REPORT_DIR=./reports

# Limites de requests (scanner ao vivo)
REQ_LIMIT=1000
REQ_PAUSE=0.55

# Integridade opcional do modelo (SHA256 do .joblib)
# MODEL_SHA256=

# Update checker (opcional): URL de um manifest JSON com latest_version/download_url/notes
ZEBRA_UPDATE_MANIFEST=
ZEBRA_API_BASE=http://127.0.0.1:8765

# Nome customizado da aplicacao (opcional)
ZEBRA_APP_NAME=Zebra Hunter Quantum Pro

# Doacao PIX (opcional)
ZEBRA_PIX_KEY=
ZEBRA_PIX_PAYLOAD=

# Banco local embutido por padrao no desktop final.
# Para usar Mongo externo, troque para mongodb://localhost:27017 ou mongodb+srv://...
MONGO_URI=embedded://local
MONGO_DB=zebra_hunter
MONGO_COLLECTION_PICKS=picks_log
MONGO_COLLECTION_LEARNING=learning_log
MONGO_COLLECTION_ALERT_RUNS=alerts_analysis_runs
MONGO_COLLECTION_ALERT_TABLES=alerts_analysis_tables
MONGO_COLLECTION_ARTIFACTS=artifacts
MONGO_COLLECTION_EVENTS=pipeline_events
MONGO_GRIDFS_BUCKET=artifacts_fs

# Observabilidade profissional (opcional)
LOG_LEVEL=INFO
LOG_JSON=0
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.10
SENTRY_PROFILES_SAMPLE_RATE=0.0

# Scheduler interno da Engine API (opcional)
ZEBRA_API_SCHEDULER_ENABLED=0
ZEBRA_API_SCAN_INTERVAL_MIN=0
ZEBRA_API_SYNC_INTERVAL_MIN=0
ZEBRA_API_UPDATE_RESULTS_INTERVAL_MIN=0
ZEBRA_SCHED_UPDATE_DAYS=2
LICENSE_REQUIRED=1
LICENSE_KEY=
LICENSE_CACHE_TTL_SEC=3600
LICENSE_GRACE_HOURS=72
LICENSE_TRIAL_DAYS=30
LICENSE_API_BASE=
LICENSE_API_TIMEOUT_SEC=8
LICENSE_API_VERIFY_SSL=1
LICENSE_API_TOKEN=
LICENSE_PAYMENT_URL=
LICENSE_PLAN_CODE=pro-monthly
LICENSE_PRODUCT_NAME=Zebra Hunter Quantum Pro
LICENSE_PRICE_BRL=29.00
LICENSE_BILLING_DAYS=30
LICENSE_MAX_DEVICES=1
LICENSE_CURRENCY=BRL
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_TABLE=licenses

# Django Web (fase 1)
DJANGO_SECRET_KEY=
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=

# Hardening de seguranca (producao)
DJANGO_SECURE_SSL_REDIRECT=0
DJANGO_SESSION_COOKIE_SECURE=0
DJANGO_CSRF_COOKIE_SECURE=0
DJANGO_SESSION_COOKIE_HTTPONLY=1
DJANGO_CSRF_COOKIE_HTTPONLY=0
DJANGO_SESSION_COOKIE_SAMESITE=Lax
DJANGO_CSRF_COOKIE_SAMESITE=Lax
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=0
DJANGO_SECURE_HSTS_PRELOAD=0
DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
DJANGO_USE_X_FORWARDED_HOST=0
DJANGO_X_FRAME_OPTIONS=DENY
DJANGO_SECURE_REFERRER_POLICY=strict-origin-when-cross-origin
DJANGO_SECURE_CROSS_ORIGIN_OPENER_POLICY=same-origin

# Logging web (producao)
DJANGO_LOG_LEVEL=INFO
DJANGO_LOG_JSON=0
DJANGO_LOG_FILE=reports/webapp/django_app.log
DJANGO_LOG_MAX_BYTES=5000000
DJANGO_LOG_BACKUP_COUNT=5

# Token opcional para health externo (UptimeRobot/Grafana/etc)
DJANGO_HEALTH_TOKEN=
DJANGO_PUBLIC_BASE_URL=

# Mercado Pago (checkout + webhook server-side)
MERCADO_PAGO_ACCESS_TOKEN=
MERCADO_PAGO_WEBHOOK_TOKEN=
MERCADO_PAGO_SUCCESS_URL=
MERCADO_PAGO_PENDING_URL=
MERCADO_PAGO_FAILURE_URL=

# Filas assíncronas (Celery + Redis)
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0
CELERY_TASK_ALWAYS_EAGER=0
CELERY_WORKER_CONCURRENCY=1
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3300

# Agendamentos (Celery Beat)
DJANGO_SCHED_SCAN_MINUTES=0
DJANGO_SCHED_UPDATE_RESULTS_MINUTES=0
DJANGO_SCHED_SCAN_DAYS=1
DJANGO_SCHED_SCAN_TOP=5
DJANGO_SCHED_SCAN_THR=0.45
DJANGO_SCHED_SCAN_MIN_BOOKS=8
DJANGO_SCHED_SCAN_MIN_CONF=0.55
DJANGO_SCHED_SCAN_MIN_EDGE=0.01
DJANGO_SCHED_SCAN_MIN_EV=0.01
DJANGO_SCHED_UPDATE_RESULTS_DAYS=2

# Backup agendado (Celery Beat)
DJANGO_SCHED_BACKUP_HOURS=0
DJANGO_BACKUP_DIR=
DJANGO_BACKUP_INCLUDE_MONGO=1
DJANGO_BACKUP_INCLUDE_DIRS=reports,models,data/processed
DJANGO_BACKUP_KEEP_LAST=14
